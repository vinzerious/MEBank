<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MEBankMAUI"
             x:Class="MEBankMAUI.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="PageBackgroundColor">#F8FAFC</Color>
            <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
            <Color x:Key="PrimaryTextColor">#0F172A</Color>
            <Color x:Key="SecondaryTextColor">#64748B</Color>
            <Color x:Key="InputBackgroundColor">#FFFFFF</Color>
            <Color x:Key="InputPlaceholderColor">#64748B</Color>
            <Color x:Key="PrimaryButtonColor">#1D4ED8</Color>
            <Color x:Key="SurfaceBorderColor">#CBD5E1</Color>

            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="{DynamicResource PageBackgroundColor}" />
            </Style>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{DynamicResource PrimaryTextColor}" />
            </Style>

            <Style TargetType="Entry">
                <Setter Property="BackgroundColor" Value="{DynamicResource InputBackgroundColor}" />
                <Setter Property="TextColor" Value="{DynamicResource PrimaryTextColor}" />
                <Setter Property="PlaceholderColor" Value="{DynamicResource InputPlaceholderColor}" />
                <Setter Property="HeightRequest" Value="48" />
                <Setter Property="ClearButtonVisibility" Value="WhileEditing" />
            </Style>

            <Style TargetType="Button">
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="HeightRequest" Value="50" />
                <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryButtonColor}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
